# Petwell — environment configuration
# Copy to .env and fill in your own Supabase project to enable the backend.
# These are EXPO_PUBLIC_* so they are inlined into the client bundle at build time.
# The anon/publishable key is safe to expose; Row Level Security protects all data.
#
# If these are NOT set, the app runs in local/demo mode (AsyncStorage) and prints
# a developer warning — it will NOT silently use a shared demo project.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Optional: opt in to the shared demo Supabase project for local development only.
# Leave unset (or "0") for any real/production build.
# EXPO_PUBLIC_USE_DEMO_SUPABASE=1

# Crash & error reporting (Sentry). A DSN is a public client key — safe to ship.
# Leave unset to disable Sentry (the app no-ops). Get it from:
# Sentry → Settings → Projects → <project> → Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.us.sentry.io/XXXXXXX

# In-app subscriptions (RevenueCat). Public SDK keys are safe to ship — they are
# embedded in every app binary. Each store has its OWN key: dashboard →
# Project settings → API keys (Apple key = appl_…, Google key = goog_…).
# Without a key for the current platform (and always on web), purchases are
# disabled and Pro stays locked — the app still runs.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxx
# Entitlement identifier that unlocks Pro — must match the RevenueCat dashboard.
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=Petwell Pro
